# ===== zernio(官方发布 API,适合原创帖 + 排期)=====
# 在 zernio.com 控制台拿 sk_ 开头的 key
ZERNIO_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx

# ===== MoreLogin(指纹浏览器,矩阵号 / 无 API 平台)=====
# MoreLogin 客户端的本地 API 地址(客户端必须在本机运行且已登录,v2.15.0+)
MORELOGIN_LOCAL_API=http://127.0.0.1:40000
# 部分版本本地 API 需要鉴权头,不需要就留空
MORELOGIN_API_ID=
# true=全自动点发布(自担风险);false=打开预填发送框、人工按发(推荐)
MORELOGIN_AUTO_SUBMIT=false

# ===== 服务 =====
PORT=8787
# SQLite 数据库文件路径(排期帖持久化;目录会自动创建)
DB_PATH=./data/vibe-marketer.db
# 真实互动数据回收频率(分钟,1-59)
ANALYTICS_REFRESH_MIN=10
# 允许的前端来源(本地开发用 Vite 默认端口)
FRONTEND_ORIGIN=http://localhost:5173
