# ===== zernio(官方发布 API,适合原创帖 + 排期)=====
# 在 zernio.com 控制台拿 sk_ 开头的 key
ZERNIO_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx

# ===== MoreLogin(指纹浏览器,矩阵号 / 无 API 平台)=====
# MoreLogin 客户端的本地 API 地址(客户端必须在本机运行且已登录,v2.15.0+)
MORELOGIN_LOCAL_API=http://127.0.0.1:40000
# 部分版本本地 API 需要鉴权头,不需要就留空
MORELOGIN_API_ID=
# true=全自动点发布(自担风险);false=打开预填发送框、人工按发(推荐)
MORELOGIN_AUTO_SUBMIT=false

# ===== 服务 =====
PORT=8787
# SQLite 数据库文件路径(排期帖持久化;目录会自动创建)
DB_PATH=./data/vibe-marketer.db
# 真实互动数据回收频率(分钟,1-59)
ANALYTICS_REFRESH_MIN=10

# ===== 追踪雷达(大V监控 + 服务端草拟回复)=====
# 服务端草拟大V回复用的 Anthropic key(留空则用 mock 草稿,仍会通知+待 approve)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# 监控频率(分钟,1-59):扫大V新帖 + niche 灵感
MONITOR_INTERVAL_MIN=3
# 大V用户帖抓取 actor(可覆盖)
# APIFY_ACTOR_TIKTOK_PROFILE=clockworks/tiktok-scraper

# ===== Apify(抓取摄入:爆款雷达 / 真收件箱 / 趋势选题)=====
# 在 apify.com 控制台拿 token;留空则相关功能返回 NO_APIFY_TOKEN(前端会提示)
# 注意:这些 actor 多为 pay-per-result,按抓取量计费
APIFY_TOKEN=
# 可选:覆盖默认 actor(默认值见 sources/apify.ts)
# APIFY_ACTOR_TIKTOK_HASHTAG=clockworks/tiktok-hashtag-scraper
# APIFY_ACTOR_TIKTOK_COMMENTS=clockworks/tiktok-comments-scraper
# APIFY_ACTOR_X_PROFILE=scraper_one/x-profile-posts-scraper
# APIFY_ACTOR_X_REPLIES=scraper_one/x-post-replies-scraper
# APIFY_ACTOR_IG_COMMENTS=apify/instagram-comment-scraper
# APIFY_ACTOR_REDDIT=harshmaur/reddit-scraper   # posts + comments + search
# 允许的前端来源(本地开发用 Vite 默认端口)
FRONTEND_ORIGIN=http://localhost:5173
